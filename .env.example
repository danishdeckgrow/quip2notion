# Get your Quip token at https://quip.com/dev/token
QUIP_TOKEN=your_quip_personal_access_token_here

# Create a Notion internal integration at https://www.notion.so/my-integrations
NOTION_TOKEN=secret_your_notion_integration_token_here

# The Notion page ID where migrated content will be placed
# Right-click a page in Notion → Copy link → the UUID at the end is the page ID
NOTION_TARGET_PAGE_ID=your_notion_target_page_id_here

# Optional: log level (trace|debug|info|warn|error) — default: info
LOG_LEVEL=info

# Optional: max concurrent API calls (1-10) — default: 4
CONCURRENCY=4
